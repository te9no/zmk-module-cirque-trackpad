menuconfig INPUT_PINNACLE
    bool "Cirque Pinnacle trackpads"
    default y
    depends on GPIO
    depends on SPI || I2C
    depends on INPUT
    depends on DT_HAS_CIRQUE_PINNACLE_ENABLED
    help
      Enable driver for Cirque Pinnacle trackpads

config INPUT_PINNACLE_STUDIO_RPC
    bool "Enable DYA trackpad custom Studio RPC"
    default y if ZMK_STUDIO_RPC
    select NANOPB
    select ZMK_SPLIT_RELAY_EVENT if ZMK_SPLIT
    help
      Enable the custom Studio RPC subsystem for the Cirque trackpad Web UI.
      This can be enabled on a central half even when the physical trackpad is
      on a peripheral half; in that case the subsystem is published, but only
      locally registered Cirque devices can be listed or controlled.

config INPUT_PINNACLE_STUDIO_RPC_SPLIT_TIMEOUT_MS
    int "DYA trackpad Studio RPC split request timeout"
    default 1200
    depends on INPUT_PINNACLE_STUDIO_RPC && ZMK_SPLIT_RELAY_EVENT

if INPUT_PINNACLE

config INPUT_PINNACLE_INIT_PRIORITY
    int "Cirque Pinnacle initialization priority"
    default INPUT_INIT_PRIORITY

if ZMK_MOUSE

config ZMK_INPUT_PINNACLE_IDLE_SLEEPER
    bool "Pinnacle Sleep linked to ZMK idle state"
    default n

endif

endif
